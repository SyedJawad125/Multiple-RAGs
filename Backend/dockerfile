# #    — added:  libmagic1      (file-type detection for resume uploads)
# #              poppler-utils  (PDF metadata, used by pdfplumber internally)
# #              libgl1          (required by PyMuPDF / fitz)
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     build-essential \
#     libpq-dev \
#     curl \
#     netcat-openbsd \
